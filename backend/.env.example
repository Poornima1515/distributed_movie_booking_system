PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/moviebooking?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_here

# Redis - use REDIS_URL for Upstash (recommended for production)
# Get this from https://upstash.com after creating a free Redis database
REDIS_URL=rediss://:your_password@your-host.upstash.io:6379

# Or use individual fields for local Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Email (use an app password, not your real password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Frontend URL (set this on Render to your Vercel URL)
FRONTEND_URL=https://your-app.vercel.app
